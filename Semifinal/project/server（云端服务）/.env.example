# .env.example – copy to .env and fill in real values before running
APP_NAME="Life Reflex Arc"
DEBUG=false

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./lifereflexarc.db
# DATABASE_URL=postgresql+asyncpg://lra:lra_dev_pass@localhost/lifereflexarc

# Redis (leave empty to use in-memory fallback)
REDIS_URL=
# REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# SOS countdown
SOS_DURATION_SEC=10

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
